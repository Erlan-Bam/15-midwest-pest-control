---
type Props = { businessName: string };
const { businessName } = Astro.props;
---

<aside class="preview-banner" aria-label="Concept disclosure">
  <span class="preview-dot" aria-hidden="true"></span>
  <span>Unofficial website concept prepared for <strong>{businessName}</strong></span>
  <span class="preview-meta">Not affiliated · owner approval required</span>
</aside>

<style>
  .preview-banner {
    position: fixed;
    inset: 0 0 auto;
    z-index: 1000;
    min-height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .6rem;
    padding: .5rem 1rem;
    background: #0f172a;
    color: #f8fafc;
    border-bottom: 1px solid rgba(255,255,255,.12);
    font-size: .72rem;
    line-height: 1.35;
    letter-spacing: .01em;
    text-align: center;
  }

  .preview-dot {
    width: .5rem;
    height: .5rem;
    flex: 0 0 auto;
    border-radius: 999px;
    background: #fbbf24;
    box-shadow: 0 0 0 4px rgba(251,191,36,.15);
  }

  .preview-meta {
    color: #94a3b8;
  }

  @media (max-width: 720px) {
    .preview-banner {
      justify-content: flex-start;
      min-height: 44px;
      text-align: left;
    }

    .preview-meta {
      display: none;
    }
  }
</style>
