---
type Props = {
  name: string;
  city: string;
};

const { name, city } = Astro.props;
---

<a class="brand" href="#top" aria-label={`${name} concept home`}>
  <img class="brand-mark" src="/yayzo-mark.png" width="44" height="44" alt="" />
  <span class="brand-copy">
    <strong>{name}</strong>
    <small>{city} · concept by yayzo.dev</small>
  </span>
</a>

<style>
  .brand {
    display: inline-flex;
    align-items: center;
    gap: .75rem;
    min-height: 48px;
    color: inherit;
    text-decoration: none;
  }

  .brand-mark {
    width: 44px;
    height: 44px;
    border: 1px solid color-mix(in srgb, var(--theme-accent) 58%, transparent);
    border-radius: 13px;
    background: #ffffff;
    object-fit: cover;
    box-shadow: 0 12px 30px color-mix(in srgb, var(--theme-accent) 22%, transparent);
  }

  .brand-copy {
    display: grid;
    gap: .15rem;
  }

  .brand-copy strong {
    max-width: 16rem;
    font-family: var(--font-display);
    font-size: .9rem;
    line-height: 1.1;
  }

  .brand-copy small {
    color: var(--theme-muted-text);
    font-size: .68rem;
    letter-spacing: .04em;
    text-transform: uppercase;
  }

  @media (max-width: 520px) {
    .brand-copy small {
      display: none;
    }

    .brand-copy strong {
      max-width: 10rem;
      font-size: .78rem;
    }
  }
</style>
