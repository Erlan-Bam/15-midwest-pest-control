---
type Props = {
  monogram: string;
  name: string;
  city: string;
};

const { monogram, name, city } = Astro.props;
---

<a class="brand" href="#top" aria-label={`${name} concept home`}>
  <span class="brand-mark" aria-hidden="true">{monogram}</span>
  <span class="brand-copy">
    <strong>{name}</strong>
    <small>{city} · website concept</small>
  </span>
</a>

<style>
  .brand {
    display: inline-flex;
    align-items: center;
    gap: .75rem;
    min-height: 48px;
    color: inherit;
    text-decoration: none;
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border: 1px solid color-mix(in srgb, var(--theme-accent) 58%, transparent);
    border-radius: 13px;
    background: var(--theme-accent);
    color: var(--theme-accent-ink, #111827);
    font-family: var(--font-display);
    font-size: .76rem;
    font-weight: 900;
    letter-spacing: -.02em;
    box-shadow: 0 12px 30px color-mix(in srgb, var(--theme-accent) 22%, transparent);
  }

  .brand-copy {
    display: grid;
    gap: .15rem;
  }

  .brand-copy strong {
    max-width: 16rem;
    font-family: var(--font-display);
    font-size: .9rem;
    line-height: 1.1;
  }

  .brand-copy small {
    color: var(--theme-muted-text);
    font-size: .68rem;
    letter-spacing: .04em;
    text-transform: uppercase;
  }

  @media (max-width: 520px) {
    .brand-copy small {
      display: none;
    }

    .brand-copy strong {
      max-width: 10rem;
      font-size: .78rem;
    }
  }
</style>
