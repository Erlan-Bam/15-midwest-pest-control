---
import {
  ArrowRight,
  BadgeCheck,
  CarFront,
  Check,
  ClipboardCheck,
  ExternalLink,
  MapPin,
  Phone,
  ShieldCheck,
  Sparkles,
  Star,
} from 'lucide-react';
import type { Prospect } from '../data/prospect';
import '../styles/preview.css';
import BrandMark from './BrandMark.astro';
import FaqAccordion from './FaqAccordion';
import HeroVisual from './HeroVisual.astro';
import PreviewBanner from './PreviewBanner.astro';
import ProofGallery from './ProofGallery';
import QuoteForm from './QuoteForm';
import ReviewCarousel from './ReviewCarousel';
import SectionHeading from './SectionHeading.astro';
import StickyMobileCTA from './StickyMobileCTA.astro';

type Props = { prospect: Prospect };
const { prospect } = Astro.props;

const darkAccent = ['#d02f42', '#0d9488', '#6d5bd0', '#e45f78', '#ff6b35'];
const accentInk = darkAccent.includes(prospect.accent) ? '#ffffff' : '#101827';
const isDark = prospect.industry === 'detailing';
const reviewUrl =
  prospect.review.sourceUrl ??
  prospect.sources.find((source) => source.label.includes('Google'))?.url ??
  prospect.sources[0].url;
const serviceIcon = prospect.industry === 'detailing' ? CarFront : prospect.industry === 'pest' ? ShieldCheck : Sparkles;
const ServiceIcon = serviceIcon;

const themeStyle = [
  `--theme-accent:${prospect.accent}`,
  `--theme-accent-soft:${prospect.accentSoft}`,
  `--theme-accent-ink:${accentInk}`,
  `--theme-ink:${prospect.ink}`,
  `--theme-bg:${prospect.surface}`,
  `--theme-surface:${prospect.surface}`,
  `--theme-muted-text:${isDark ? '#b8c4d6' : '#596579'}`,
  `--theme-border:${isDark ? 'rgba(255,255,255,.14)' : 'rgba(15,23,42,.12)'}`,
  `--theme-card:${isDark ? 'rgba(255,255,255,.055)' : '#ffffff'}`,
  `--theme-elevated:${isDark ? '#18212f' : '#ffffff'}`,
  `--theme-review-card:${isDark ? '#132235' : prospect.ink}`,
  `--theme-accent-strong:color-mix(in srgb, ${prospect.accent} 72%, ${prospect.ink})`,
  `--theme-hero-shadow:${isDark ? '0 34px 90px rgba(0,0,0,.42)' : '0 34px 90px rgba(15,23,42,.15)'}`,
].join(';');
---

<div
  class:list={['preview-shell', `industry-${prospect.industry}`, isDark && 'theme-dark', `variant-${prospect.visualVariant}`]}
  style={themeStyle}
>
  <PreviewBanner businessName={prospect.businessName} />

  <header class="site-header" id="top">
    <div class="container header-inner">
      <BrandMark name={prospect.businessName} city={prospect.city} />
      <nav class="desktop-nav" aria-label="Primary navigation">
        <a href="#services">Services</a>
        <a href="#process">Process</a>
        <a href="#proof">Proof</a>
        <a href="#faq">FAQ</a>
      </nav>
      <a class="header-call" href={`tel:${prospect.phoneHref}`} aria-label={`Call ${prospect.businessName} at ${prospect.phone}`}>
        <Phone aria-hidden="true" size={17} />
        <span>{prospect.phone}</span>
      </a>
    </div>
  </header>

  <main id="main-content">
    <section class="hero-section">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">
            <span aria-hidden="true"></span>
            {prospect.heroKicker}
          </p>
          <h1>{prospect.heroTitle}</h1>
          <p class="hero-description">{prospect.heroDescription}</p>

          <div class="hero-actions">
            <a class="button primary" href="#quote">
              {prospect.primaryCta}
              <ArrowRight aria-hidden="true" size={19} />
            </a>
            <a class="button secondary" href={`tel:${prospect.phoneHref}`}>
              <Phone aria-hidden="true" size={18} />
              Call {prospect.phone}
            </a>
          </div>

          <ul class="hero-microproof" aria-label="Verified public information">
            <li><MapPin aria-hidden="true" size={17} /> {prospect.city}, {prospect.state}</li>
            <li><BadgeCheck aria-hidden="true" size={17} /> Public facts sourced</li>
            <li><ShieldCheck aria-hidden="true" size={17} /> Noindex concept</li>
          </ul>
        </div>

        <HeroVisual
          industry={prospect.industry}
          businessName={prospect.businessName}
          visualVariant={prospect.visualVariant}
        />
      </div>
    </section>

    <section class="trust-strip" aria-label="Public business facts">
      <div class="container trust-grid">
        <a class="review-proof" href={reviewUrl} target="_blank" rel="noreferrer">
          <span class="rating-number">{prospect.review.rating.toFixed(1)}</span>
          <span class="rating-copy">
            <span class="stars" aria-label={`${prospect.review.rating} out of 5 stars`}>
              {Array.from({ length: 5 }).map((_, index) => <Star aria-hidden="true" size={14} fill={index < Math.round(prospect.review.rating) ? 'currentColor' : 'none'} />)}
            </span>
            <strong>{prospect.review.count} Google Maps reviews</strong>
            <small>Public listing snapshot · July 17, 2026</small>
          </span>
          <ExternalLink aria-hidden="true" size={17} />
        </a>

        {prospect.highlights.map((highlight) => (
          <div class="trust-item">
            <span>{highlight.label}</span>
            <strong>{highlight.value}</strong>
          </div>
        ))}
      </div>
    </section>

    <section class="section services-section" id="services">
      <div class="container">
        <SectionHeading
          eyebrow="Service paths"
          title={prospect.industry === 'pest' ? 'Start with what you noticed.' : prospect.industry === 'cleaning' ? 'Choose the clean you need.' : 'Choose the finish you want.'}
          description="Every card uses verified public information or carries an explicit owner-confirmation label. No packages, prices, or guarantees have been invented."
        />

        <div class="service-grid">
          {prospect.services.map((service, index) => (
            <article class="service-card">
              <span class="service-index">0{index + 1}</span>
              <span class="service-icon" aria-hidden="true"><ServiceIcon size={26} strokeWidth={1.75} /></span>
              <h3>{service.title}</h3>
              <p>{service.description}</p>
              <span class:list={['fact-status', service.confirmationRequired && 'needs-confirmation']}>
                {service.confirmationRequired ? <ClipboardCheck aria-hidden="true" size={15} /> : <Check aria-hidden="true" size={15} />}
                {service.confirmationRequired ? 'Owner confirmation' : 'Public fact verified'}
              </span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section process-section" id="process">
      <div class="container process-layout">
        <div class="process-copy">
          <SectionHeading
            eyebrow="How it works"
            title="Three steps, with the owner in control."
            description="The preview collects useful context without promising availability, pricing, or a treatment result."
          />
          <a class="text-link" href="#quote">
            Preview the request flow <ArrowRight aria-hidden="true" size={18} />
          </a>
        </div>
        <ol class="process-list">
          {prospect.process.map((step, index) => (
            <li>
              <span>{index + 1}</span>
              <div>
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="section proof-section" id="proof">
      <div class="container">
        <SectionHeading
          eyebrow="Visual proof"
          title="A gallery structure, ready for approved work."
          description="No Google Maps photos or customer images were copied. These interactive frames remain labelled placeholders until the owner supplies rights-cleared photography."
        />
        <ProofGallery client:load industry={prospect.industry} />
      </div>
    </section>

    <ReviewCarousel client:load review={prospect.review} />

    <section class="section area-section">
      <div class="container area-layout">
        <div class="area-map" aria-label={`Concept service-area map for ${prospect.city}`}>
          <div class="map-grid" aria-hidden="true"></div>
          <span class="map-ring ring-one" aria-hidden="true"></span>
          <span class="map-ring ring-two" aria-hidden="true"></span>
          <span class="map-pin"><MapPin aria-hidden="true" size={26} /></span>
          <p>{prospect.city}, {prospect.state}</p>
          <small>Illustrative coverage · exact radius needs approval</small>
        </div>
        <div class="area-copy">
          <p class="eyebrow-simple">Service area</p>
          <h2>Local clarity before the request.</h2>
          <p>Only the public city is treated as verified. Nearby coverage remains clearly labelled until the owner confirms the actual radius.</p>
          <ul>
            {prospect.serviceAreas.map((area) => (
              <li><MapPin aria-hidden="true" size={17} /> {area}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="section faq-section" id="faq">
      <div class="container faq-layout">
        <SectionHeading
          eyebrow="Frequently asked"
          title="Quick answers before you call."
          description="Short answers based on public business information, ready for the owner to refine before launch."
        />
        <FaqAccordion client:load items={prospect.faq} />
      </div>
    </section>

    <section class="section quote-section" id="quote">
      <div class="container quote-layout">
        <div class="quote-copy">
          <p class="eyebrow-simple">Preview request flow</p>
          <h2>{prospect.primaryCta}.</h2>
          <p>
            This interaction is intentionally disconnected. It demonstrates the lead flow without contacting {prospect.businessName} or collecting visitor data.
          </p>
          <div class="contact-card">
            <span class="contact-icon" aria-hidden="true"><Phone size={21} /></span>
            <div>
              <small>Public phone</small>
              <a href={`tel:${prospect.phoneHref}`}>{prospect.phone}</a>
            </div>
          </div>
          <div class="contact-card">
            <span class="contact-icon" aria-hidden="true"><MapPin size={21} /></span>
            <div>
              <small>Verified public location</small>
              <strong>{prospect.city}, {prospect.state}</strong>
            </div>
          </div>
        </div>
        <QuoteForm
          client:load
          businessName={prospect.businessName}
          industry={prospect.industry}
          services={prospect.services.map((service) => service.title)}
        />
      </div>
    </section>

    <section class="research-section" aria-labelledby="research-heading">
      <div class="container research-layout">
        <div>
          <p class="eyebrow-simple">Research & approval</p>
          <h2 id="research-heading">What this concept knows—and what it does not.</h2>
          <p>{prospect.websiteSituation}</p>
        </div>
        <details>
          <summary>View public sources</summary>
          <ul>
            {prospect.sources.map((source) => (
              <li>
                <a href={source.url} target="_blank" rel="noreferrer">{source.label} <ExternalLink aria-hidden="true" size={14} /></a>
                <span>{source.supports}</span>
              </li>
            ))}
          </ul>
        </details>
        <details>
          <summary>View owner-confirmation list</summary>
          <ul class="confirmation-list">
            {prospect.ownerConfirmations.map((item) => <li><ClipboardCheck aria-hidden="true" size={16} /> {item}</li>)}
          </ul>
        </details>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-grid">
      <div>
        <BrandMark name={prospect.businessName} city={prospect.city} />
        <p>Unofficial, noindex website concept by yayzo.dev. Not affiliated with or endorsed by the business.</p>
      </div>
      <div class="footer-links">
        <a href="#services">Services</a>
        <a href="#top">Back to top</a>
        <a href={reviewUrl} target="_blank" rel="noreferrer">Public listing</a>
      </div>
      <p class="footer-note">Facts re-checked July 17, 2026. Rating snapshots and every marked item require confirmation before public business use.</p>
    </div>
  </footer>

  <StickyMobileCTA
    phone={prospect.phone}
    phoneHref={prospect.phoneHref}
    primaryCta={prospect.primaryCta}
  />
</div>
