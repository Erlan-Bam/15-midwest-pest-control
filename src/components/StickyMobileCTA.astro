---
import { Phone, Sparkles } from 'lucide-react';

type Props = {
  phone: string;
  phoneHref: string;
  primaryCta: string;
};

const { phone, phoneHref, primaryCta } = Astro.props;
---

<nav class="mobile-cta" aria-label="Quick contact actions">
  <a href={`tel:${phoneHref}`}>
    <Phone aria-hidden="true" size={18} />
    <span>Call <small>{phone}</small></span>
  </a>
  <a class="primary" href="#quote">
    <Sparkles aria-hidden="true" size={18} />
    <span>{primaryCta}</span>
  </a>
</nav>

<style>
  .mobile-cta {
    display: none;
  }

  @media (max-width: 720px) {
    .mobile-cta {
      position: fixed;
      inset: auto .75rem .75rem;
      z-index: 900;
      display: grid;
      grid-template-columns: .86fr 1.14fr;
      gap: .5rem;
      padding: .45rem;
      border: 1px solid var(--theme-border);
      border-radius: 1.1rem;
      background: color-mix(in srgb, var(--theme-surface) 90%, transparent);
      box-shadow: 0 18px 50px rgba(15,23,42,.22);
      backdrop-filter: blur(18px);
    }

    a {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: .5rem;
      min-height: 50px;
      border-radius: .8rem;
      color: var(--theme-ink);
      font-size: .72rem;
      font-weight: 850;
      line-height: 1.1;
      text-decoration: none;
    }

    a.primary {
      background: var(--theme-accent);
      color: var(--theme-accent-ink);
    }

    a span {
      display: grid;
      gap: .14rem;
    }

    a small {
      color: var(--theme-muted-text);
      font-size: .59rem;
      font-weight: 700;
    }
  }
</style>
