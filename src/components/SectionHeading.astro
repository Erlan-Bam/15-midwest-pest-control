---
type Props = {
  eyebrow: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
};

const { eyebrow, title, description, align = 'left' } = Astro.props;
---

<header class:list={['section-heading', align === 'center' && 'center']}>
  <p>{eyebrow}</p>
  <h2>{title}</h2>
  {description && <span>{description}</span>}
</header>

<style>
  .section-heading {
    max-width: 46rem;
  }

  .section-heading.center {
    margin-inline: auto;
    text-align: center;
  }

  p {
    margin: 0 0 .85rem;
    color: var(--theme-accent-strong);
    font-size: .75rem;
    font-weight: 900;
    letter-spacing: .14em;
    text-transform: uppercase;
  }

  h2 {
    margin: 0;
    color: var(--theme-ink);
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 4.5rem);
    line-height: .98;
    letter-spacing: -.055em;
  }

  span {
    display: block;
    max-width: 42rem;
    margin-top: 1.15rem;
    color: var(--theme-muted-text);
    font-size: clamp(1rem, 1.8vw, 1.16rem);
    line-height: 1.7;
  }

  .center span {
    margin-inline: auto;
  }
</style>
