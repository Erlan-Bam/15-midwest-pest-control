---
import BaseLayout from '../layouts/BaseLayout.astro';
import PreviewPage from '../components/PreviewPage.astro';
import { prospect } from '../data/prospect';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: prospect.businessName,
  telephone: prospect.phoneHref,
  address: {
    '@type': 'PostalAddress',
    addressLocality: prospect.city,
    addressRegion: prospect.state,
    addressCountry: 'US',
  },
  areaServed: {
    '@type': 'City',
    name: prospect.city,
  },
};
---

<BaseLayout
  title={`${prospect.businessName} — Unofficial Website Concept`}
  description={`Unofficial noindex website concept prepared for ${prospect.businessName} in ${prospect.city}, ${prospect.state}.`}
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <PreviewPage prospect={prospect} />
</BaseLayout>
